#!/bin/sh
set -e -x

# Using a newer Clang mirror that includes LLD and LLVM tools
CLANG_REPO="https://github.com/kdrag0n/proton-clang"
WORK="${HOME}/work"
KERNEL_SRC="${WORK}/myKernel"

mkdir -p "${WORK}"
cd "${WORK}"

# Clone Clang (Proton Clang is great for "Clang-only" builds)
[ ! -d clang ] && git clone --depth=1 "${CLANG_REPO}" clang

# Clone Kernel Source
[ ! -d myKernel ] && git clone --depth=1 "https://github.com/ansh-m14x/kernel-oppo-a31" -b android-9.0 myKernel

# Setting Path
PATH="${WORK}/clang/bin:/usr/bin:/bin"

cd "${KERNEL_SRC}"

# Compilation using LLVM=1 (This tells it to use Clang for CC, LD, AR, etc.)
make O=out ARCH=arm64 oppo6765_19581_defconfig

make -j$(nproc --all) O=out ARCH=arm64 \
    CC=clang \
    LLVM=1 \
    LLVM_IAS=1 \
    CLANG_TRIPLE=aarch64-linux-gnu- \
    CROSS_COMPILE=aarch64-linux-gnu- \
    CROSS_COMPILE_ARM32=arm-linux-gnueabi- 2>&1 | tee build.log
