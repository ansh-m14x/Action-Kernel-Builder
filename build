#!/bin/sh

set -e -x

# --- Configuration ---
# Kernel Source
KERNEL_SOURCE="https://github.com/ansh-m14x/kernel-oppo-a31"
KERNEL_BRANCH="Nethunter"
KERNEL_DEFCONFIG="oppo6765_19581_defconfig"

# --- Toolchains ---
CLANG_REPO="https://github.com/KAGA-KOKO/clang-6.0.2"
GCC_x64="https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/aarch64/aarch64-linux-android-4.9"
GCC_x32="https://android.googlesource.com/platform/prebuilts/gcc/linux-x86/arm/arm-linux-androideabi-4.9"
GCC_BRANCH="master-kernel-build-2021"

# --- Setup Paths ---
WORK="${HOME}/work"
KERNEL="myKernel"
KERNEL_SRC="${WORK}/${KERNEL}"
NH_CONFIG="${WORK}/nethunter.config" # Ensure this file exists in your work folder

# --- Environment Setup ---
mkdir -p "${WORK}"
cd "${WORK}" || exit 1

# Clone dependencies
[ ! -d clang ] && git clone --depth=1 "${CLANG_REPO}" ./clang
[ ! -d x64 ] && git clone --depth=1 "${GCC_x64}" -b "${GCC_BRANCH}" ./x64
[ ! -d x32 ] && git clone --depth=1 "${GCC_x32}" -b "${GCC_BRANCH}" ./x32
[ ! -d "${KERNEL}" ] && git clone --depth=1 "${KERNEL_SOURCE}" -b "${KERNEL_BRANCH}" "${KERNEL}"

# Set Path
PATH="${WORK}/clang/bin:${WORK}/x64/bin:${WORK}/x32/bin:/usr/bin:/bin"
export PATH

# --- Build Process ---
cd "${KERNEL_SRC}" || exit 1

# Setup make Command
# NOTE: If you experience Wi-Fi issues, change CC=clang to CC=aarch64-linux-android-gcc
make_fun() {
    make O=out ARCH=arm64 \
        CC=clang HOSTCC=clang \
        CLANG_TRIPLE=aarch64-linux-gnu- \
        CROSS_COMPILE=aarch64-linux-android- "$@"
}

# 1. Clean previous build
rm -rf out

# 2. Merge NetHunter Config over Base Defconfig
echo "Merging configurations..."
./scripts/kconfig/merge_config.sh -O out arch/arm64/configs/"${KERNEL_DEFCONFIG}" "${NH_CONFIG}"

# 3. Compile
echo "Starting kernel compilation..."
make_fun -j"$(nproc --all)" 2>&1 | tee build.log
